{
  "name": "@my-org/shared-ui",
  "version": "0.1.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./globals.css": "./dist/globals.css"
  },
  "files": [
  "dist",
  "tailwind.config.js"
],
