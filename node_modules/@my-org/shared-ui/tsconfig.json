{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    "rootDir": "src",
    "outDir": "dist",

    "declaration": true,
    "declarationMap": true,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}